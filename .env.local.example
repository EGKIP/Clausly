# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Server-only. Required for the notifications dispatch + unsubscribe routes.
# Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Used to build absolute links in transactional emails. Default is localhost:3000.
BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Stripe billing (Track II) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# --- AI providers (Track R) ---
# 'mock' (default), 'openai', or 'anthropic'.
CLAUSLY_AI_PROVIDER=mock
# Optional override. Defaults: gpt-4o-mini (openai), claude-3-5-haiku-latest (anthropic).
CLAUSLY_AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- OCR fallback (Track S) ---
# Set to 'true' to enable Tesseract.js fallback when PDF text extraction is empty.
CLAUSLY_OCR_ENABLED=false

# --- Document Q&A / RAG (Track CC) ---
# Defaults to CLAUSLY_AI_PROVIDER. Use 'mock' for local/dev or 'openai' in production.
CLAUSLY_EMBEDDING_PROVIDER=openai
CLAUSLY_EMBEDDING_MODEL=text-embedding-3-small
# Bearer secret for one-off admin backfills of document_chunks after deploy.
CLAUSLY_ADMIN_SECRET=

# --- Email notifications (Track T) ---
RESEND_API_KEY=
# Verified sender, e.g. 'Clausly <support@cloudly.app>'.
CLAUSLY_EMAIL_FROM=Clausly <support@cloudly.app>
# Public support inbox used for reply-to links in product email.
CLAUSLY_SUPPORT_EMAIL=support@cloudly.app
# Shared secret for manual / external triggers of the dispatch route.
# Vercel Cron uses CRON_SECRET (below) instead; both are accepted.
# Generate with: openssl rand -base64 32
CLAUSLY_DISPATCH_SECRET=
# HMAC signing secret for unsubscribe tokens. Rotate by changing it and bumping
# users.notification_preferences.version. Generate with:
#   openssl rand -base64 32
CLAUSLY_UNSUBSCRIBE_SECRET=
# Resend webhook signing secret (Svix). Found in the Resend dashboard under
# Webhooks → your endpoint → Signing Secret.
RESEND_WEBHOOK_SECRET=

# --- Vercel Cron (production only) ---
# Sent automatically by Vercel as `Authorization: Bearer ${CRON_SECRET}` on
# scheduled invocations of /api/notifications/dispatch. Set in the Vercel
# project env, not in .env.local. Generate with: openssl rand -base64 32
CRON_SECRET=
